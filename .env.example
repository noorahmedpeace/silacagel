# DryGelWorld public site configuration
# Safe to expose in browser because these are public brand/contact values.
NEXT_PUBLIC_SITE_URL=https://www.drygelworld.com
NEXT_PUBLIC_SITE_NAME=Dry Gel World
NEXT_PUBLIC_BRAND_NAME=DryGelWorld
NEXT_PUBLIC_BRAND_DOMAIN=drygelworld.com
NEXT_PUBLIC_DEFAULT_SEO_IMAGE=/images/og-image.png

# Google Search Console verification token
# This is not a password, but keep the live value in Vercel Environment Variables.
GOOGLE_SITE_VERIFICATION=DF-Lv79GdccoyRnUPdGDn3Lgp521O_gBJ-ejnmtCDBk

# Public sales/contact details used by CTAs, WhatsApp links, and structured data
NEXT_PUBLIC_WHATSAPP_NUMBER=923330223337
NEXT_PUBLIC_SALES_PHONE_DISPLAY=+92 333 022 3337
NEXT_PUBLIC_SALES_PHONE_HREF=+923330223337
NEXT_PUBLIC_SALES_EMAIL=
NEXT_PUBLIC_COMPANY_CITY=Karachi
NEXT_PUBLIC_COMPANY_COUNTRY=Pakistan
NEXT_PUBLIC_SERVICE_AREA=Worldwide

# RFQ delivery (server action: src/app/actions/submit-rfq.ts).
# Until RESEND_API_KEY + RFQ_FROM are set, the form gracefully falls back to a
# pre-filled mailto: so leads are never silently dropped.
RESEND_API_KEY=
RFQ_FROM=DryGelWorld RFQ <rfq@drygelworld.com>
# Optional internal archive inbox BCC'd on every RFQ:
RFQ_BCC=

# Optional future integrations. Add these only when the feature exists.
# DATAFORSEO_LOGIN=
# DATAFORSEO_PASSWORD=
# AHREFS_API_TOKEN=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_LINKEDIN_COMPANY_URL=
# NEXT_PUBLIC_ALIBABA_PROFILE_URL=
# NEXT_PUBLIC_EXPORTHUB_PROFILE_URL=

# Optional: Facebook App ID to satisfy the Sharing Debugger fb:app_id warning.
# Not required for link sharing. Create an app at https://developers.facebook.com/
# then set the numeric App ID here (and in Vercel env). Leave blank to omit the tag.
NEXT_PUBLIC_FB_APP_ID=
